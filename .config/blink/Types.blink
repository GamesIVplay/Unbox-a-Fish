type Entity = f64

type Cash = f64
type ToolLevel = u16
type LuckLevel = u16
type TutorialStep = u8

enum Mutation = {Normal, Gold, Diamond, Rainbow, Shocked, Candy, BloodMoon}
map Index = { [Mutation]: string[] }
map Stock = { [string]: f64 }

enum Rarity = {Common, Rare, Epic, Legendary, Mythic, Secret}

type FriendBoost = f16

type Slot = u16

struct Item {
    Name: string,
    Mutation: Mutation?,
    Amount: f64
}

map Inventory = { [string]: Item }
